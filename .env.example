# === Telegram ===
# From @BotFather. Enable Business Mode and turn OFF Group Privacy in Bot Settings.
BOT_TOKEN=

# === MongoDB ===
MONGO_URL=mongodb://localhost:27017
MONGO_DB=tg_ai_assistant

# === Anthropic (Claude — Tier 2 extraction) ===
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
# Adaptive thinking effort for the extraction call: low | medium | high | max
ANTHROPIC_EFFORT=medium

# === Qwen via Ollama (Tier 1 triage, OpenAI-compatible endpoint) ===
QWEN_BASE_URL=http://localhost:11434/v1
QWEN_MODEL=qwen2.5:32b-instruct
# Ollama ignores the key, but the OpenAI SDK requires a non-empty value.
QWEN_API_KEY=ollama

# === TickTick MCP (Railway, Streamable HTTP) ===
# Full URL including the secret path: https://<app>.up.railway.app/mcp/<MCP_SECRET>
TICKTICK_MCP_URL=

# === Pipeline tuning (defaults match the spec) ===
BATCH_INTERVAL_MIN=30
CONV_GAP_HOURS=6
MAX_LOOKBACK_HOURS=48
RAW_TTL_DAYS=30
DEFAULT_PROJECT=Inbox
