# tg-ai-assistant — environment reference.
# Matches app/config.py 1:1 (plus the few vars read directly from the process
# environment, marked below). Values shown are the code defaults; blank means
# "no default — set it if you need the feature".
#
# MINIMUM for a working deploy: BOT_TOKEN, ANTHROPIC_API_KEY, MONGO_URL,
# DEFAULT_TIMEZONE (+ WEBAPP_URL for the Mini App). TickTick can be set here via
# TICKTICK_MCP_URL or connected from inside the bot afterwards (/connect).
#
# SINGLE-TENANT by design: every person deploys their OWN isolated instance
# (own bot, own MongoDB, own Anthropic key, own ticktick-mcp). This instance
# only ever serves ONE owner (owner = user #1, the first to connect Business).

# === Telegram ===
# From @BotFather. Enable Business Mode (a.k.a. "Secretary Mode") and turn OFF
# Group Privacy in Bot Settings. This must be YOUR OWN bot.
BOT_TOKEN=

# === MongoDB ===
# On Railway, add the MongoDB plugin and reference it: ${{MongoDB.MONGO_URL}}.
MONGO_URL=mongodb://localhost:27017
MONGO_DB=tg_ai_assistant

# === Onboarding crypto key (OPTIONAL) ===
# Read directly from the environment (app/onboarding/crypto.py), not via
# config.py. No longer required for TickTick — the single instance TickTick URL
# lives in TICKTICK_MCP_URL / bot_state (see /connect below), NOT an encrypted
# per-user vault. Kept only for the onboarding crypto helper; leave unset unless
# a feature that uses it is enabled. Generate once:  openssl rand -hex 32
# TOKEN_ENC_KEY=

# === Anthropic (Claude — Tier 2 extraction) ===
# Your own Anthropic API key. Usage is billed to this key only.
# (Not needed if you run extraction through a CLAUDE_CLI_URL shim — see below.)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
# Adaptive thinking effort for the extraction call: low | medium | high | max
ANTHROPIC_EFFORT=medium
# Default extraction model + effort when a chat has no per-chat/global Mini App
# override (both are overridable in the Mini App "settings cabinet"). EXTRACT_MODEL
# is a short alias (opus|sonnet|haiku); empty → CLAUDE_CLI_MODEL on the shim path,
# ANTHROPIC_MODEL on the API path. EXTRACT_EFFORT (low|medium|high|max) applies
# only on the API path; empty → ANTHROPIC_EFFORT.
EXTRACT_MODEL=
EXTRACT_EFFORT=
# Optional override of the built-in base extraction prompt (guidance body only —
# the JSON-output contract is always appended). Empty → built-in default. Usually
# left blank here and edited per-chat/globally in the Mini App instead.
SYSTEM_PROMPT=

# === Claude via CLI shim (optional alternative to the paid API) ===
# Runs tier-2 extraction through a token-gated `claude -p` HTTP shim (i.e. a
# Claude Code subscription) instead of the Anthropic API. When CLAUDE_CLI_URL is
# set there is NO API fallback: if the shim is unreachable the chat stays dirty
# and is retried later. Empty → use ANTHROPIC_API_KEY.
CLAUDE_CLI_URL=
CLAUDE_CLI_TOKEN=
# Claude Code model alias (opus | sonnet | full model id) and request timeout, s.
CLAUDE_CLI_MODEL=opus
CLAUDE_CLI_TIMEOUT=300

# === «Контроль» attribution in DMs ===
# What happens when a DM task's action is on the OTHER person (delegated or
# volunteered): "on" → it becomes a tracked «Контроль» item; "off" → it is not
# created at all. Groups are unaffected. Overridable globally & per-chat in the
# Mini App. The marker is prefixed to the title; the tag is applied in TickTick
# (empty value = skip that marker).
CONTROL_MODE=on
CONTROL_MARKER=👁
CONTROL_TAG=контроль

# === Qwen via Ollama (Tier 1 triage, OpenAI-compatible endpoint) — OPTIONAL ===
# Cheap local triage that gates the Claude calls. OFF by default (empty): a fresh
# deploy skips tier-1 entirely (no localhost call) and sends everything straight
# to Claude. To enable it, run an OpenAI-compatible endpoint (e.g. Ollama) and set
# QWEN_BASE_URL here or in the Mini App global settings. Unreachable → fails OPEN.
QWEN_BASE_URL=
QWEN_MODEL=qwen2.5:32b-instruct
# Ollama ignores the key, but the OpenAI SDK requires a non-empty value.
# Also reused as the bearer token for TRANSCRIBE_URL.
QWEN_API_KEY=ollama

# === Voice transcription (optional Whisper endpoint) ===
# Full URL of a /transcribe endpoint. Empty → voice/audio messages skipped.
# Auth reuses QWEN_API_KEY as the bearer token.
TRANSCRIBE_URL=

# === TickTick MCP (Streamable HTTP) ===
# The SINGLE global TickTick connector for this instance. Two ways to set it:
#   1. this env var, or
#   2. DM the bot  /connect https://<your-app>.up.railway.app/mcp/<MCP_SECRET>
#      which stores it as a runtime override in bot_state (takes priority over
#      this env). No encrypted vault, no per-user URLs.
# It MUST point to YOUR OWN ticktick-mcp instance — the URL+secret controls WHOSE
# TickTick account tasks are written to. Deploy your own first (see README) and
# never reuse a URL someone shared with you, or your tasks land in their account.
TICKTICK_MCP_URL=

# === Extraction watchdog ===
# The bot probes the chain (Qwen → Claude → TickTick) every HEALTHCHECK_INTERVAL_MIN
# and DMs the owner in Russian when something breaks: immediately on a NEW error,
# then at most once/day while it persists (the daily repeat is held until
# HEALTHCHECK_HOUR local, in DEFAULT_TIMEZONE).
HEALTHCHECK_ENABLED=true
HEALTHCHECK_INTERVAL_MIN=10
HEALTHCHECK_HOUR=9

# === End-of-day group summary ===
# Once a day (SUMMARY_HOUR local, in DEFAULT_TIMEZONE) the bot posts a short
# Russian recap INTO each group chat: tasks it created and completed/updated
# that day. OFF by default — opt in PER CHAT (or here globally) via the Mini App
# "Итог дня" toggle. Only groups get it, and only on days with activity.
DAILY_SUMMARY=off
SUMMARY_HOUR=19

# === Pipeline tuning ===
# Scheduler tick, in minutes. The debounce design (below) does the real gating,
# so this is just a small poll interval — 2 is fine. It only queries Mongo and
# processes chats that have actually settled.
BATCH_INTERVAL_MIN=2
# Debounce: process a chat once it's been quiet this long (a finished thought)…
QUIET_MINUTES=8
# …or force-process if it's been dirty at least this long (never-quiet safety).
MAX_DIRTY_MINUTES=45
CONV_GAP_HOURS=6
MAX_LOOKBACK_HOURS=48
# Raw-message retention (~3 months by default; tiny, ~2MB/month). Changing it
# recreates the TTL index automatically. Long-term memory (summaries, vectors)
# is separate and permanent.
RAW_TTL_DAYS=90

# === Audit / restore logging (Phase 0 — foundation) ===
# A durable, append-only `audit_log` records every change to your TickTick/Google
# state (who/what/when + before/after) so almost anything can be restored, for
# ~90 days. Two capture planes land in one log: in-band (changes WE make via an
# MCP) and out-of-band (changes you make in the app, or a collaborator makes in a
# shared list — caught by a read-only delta poller). Fail-open: when disabled or
# misconfigured the writers no-op and the poller no-ops — audit logging never
# breaks the pipeline. Set AUDIT_ENABLED=false to turn the whole plane off.
AUDIT_ENABLED=true
# Retention: TTL on audit_log.ts. Default 90 days (7776000s); changing it
# recreates the TTL index automatically (like RAW_TTL_DAYS). Sizing is tiny.
AUDIT_TTL_SECONDS=7776000
# Out-of-band delta poll cadence (seconds). Default 5 min. The floor is the
# provider's rate limits, not cost. Phase 0 polls TickTick only (read-only);
# Google pollers land in a later phase.
AUDIT_POLL_INTERVAL_SECONDS=300

DEFAULT_PROJECT=Inbox
# Fallback project id for unbound chats. Use the built-in Inbox id (inbox<uid>),
# which get_projects does not return. Takes priority over DEFAULT_PROJECT.
DEFAULT_PROJECT_ID=
# Section (column) inside the default project for unbound tasks, so they are easy
# to triage. Matched by name. Only set this if your default project actually has
# a column with this name; empty = tasks go to the project root.
DEFAULT_SECTION=
# Explicit column id for the default section. REQUIRED for the built-in Inbox,
# whose columns the API does not list (so DEFAULT_SECTION by name fails there).
# When set, it's sent as column_id directly. Takes priority over DEFAULT_SECTION.
DEFAULT_SECTION_ID=

# IANA timezone for TIMED deadlines that name a clock time but no city (e.g.
# "созвон в 18:00"). Set it to YOUR OWN zone, e.g. America/Los_Angeles. All-day
# (date-only) deadlines are zone-independent and never offset.
# IMPORTANT: keep this EQUAL to ticktick-mcp's USER_TIMEZONE and your TickTick
# account's display zone — otherwise timed deadlines land in the wrong local time
# (see #36). Default UTC only avoids silent offsets on a fresh deploy; the bot
# logs a startup warning while this is still UTC.
DEFAULT_TIMEZONE=UTC

# === Retrieval memory (optional) ===
# Embeds processed messages into a permanent archive and injects the most
# relevant past ones into Claude — deep recall without widening the window.
# Shares QWEN_BASE_URL / QWEN_API_KEY; without a reachable endpoint it is
# effectively off. Empty EMBED_MODEL disables retrieval (and semantic dedup).
EMBED_MODEL=bge-m3
RETRIEVE_TOP_K=6
RETRIEVE_MIN_SCORE=0.45

# === Semantic near-duplicate dedup (optional) ===
# Before creating a task, compare it (cosine, via EMBED_MODEL) against existing
# OPEN tasks — the chat's own, the bound TickTick project's, and every routed
# destination's — using THREE bands against the single best match (a single
# threshold isn't safe: real dups sit ~0.86 while distinct-but-related tasks
# reach ~0.83, and a false merge DROPS a real task):
#   cosine >= DEDUP_HIGH             → duplicate (auto: enrich the existing, skip)
#   cosine <= DEDUP_LOW              → distinct  (create)
#   between                          → a cheap LLM judge (DEDUP_JUDGE_MODEL) decides
# On ANY uncertainty (judge/embeddings/LLM down) it CREATES — never drops a task.
# Falls back to exact-title-hash dedup when off or embeddings are unavailable.
# All knobs are global + per-chat overridable in the Mini App (like CONTROL_MODE).
DEDUP_SEMANTIC=on
DEDUP_LOW=0.83
DEDUP_HIGH=0.93
# Gray-zone yes/no judge: CLI-shim alias (sonnet|haiku|opus) or a full API id.
DEDUP_JUDGE_MODEL=sonnet
# Max project tasks embedded/compared per run (stored embeddings are reused).
DEDUP_PROJECT_TASK_CAP=200
# Deprecated (superseded by the DEDUP_LOW/DEDUP_HIGH bands); accepted but unused.
# DEDUP_SIMILARITY=0.86

# === Mini App / web server ===
# Public https origin of this service (Railway domain). Drives the Telegram
# menu button and is the origin the WebApp calls back to. Leave empty to
# disable the menu button (the API/server still runs).
WEBAPP_URL=
# Railway injects PORT automatically; only set locally if you need a fixed port.
PORT=8080

# === Onboarding (optional, public self-host) ===
# The project is a PUBLIC repo and everyone runs their OWN fully-isolated copy.
# These two values only populate the /start message a non-owner sees, pointing
# them at how to get their own bot. Both optional; empty = generic text.
# Link to the public source repo.
ONBOARDING_REPO_URL=
# One-click "Deploy on Railway" template URL, if you published one.
ONBOARDING_RAILWAY_TEMPLATE_URL=

# Connector onboarding (/invite + /setup buttons). The bot hands invited people
# a one-command installer for their OWN TickTick + Google MCP servers, delivered
# via a self-destruct note. These are the OWNER's SHARED secrets — anyone who
# redeems an invite receives them. Leave empty to disable a given connector.
# Self-Destroyed-Notes service origin (delivers the one-time links):
NOTES_BASE_URL=
# Shared Google OAuth client + relay (see the Google MCP hub / its setup.sh):
ONBOARDING_GOOGLE_CLIENT_ID=
ONBOARDING_GOOGLE_CLIENT_SECRET=
ONBOARDING_RELAY_SECRET=
# ONBOARDING_RELAY_URL has a default (the shared relay); override only if needed.
# ONBOARDING_GOOGLE_SETUP_URL defaults to the published Google setup.sh.
# Shared TickTick OAuth client:
ONBOARDING_TICKTICK_CLIENT_ID=
ONBOARDING_TICKTICK_CLIENT_SECRET=
# ONBOARDING_TICKTICK_SETUP_URL defaults to the published TickTick setup.sh.
# ONBOARDING_ASSISTANT_SETUP_URL defaults to this repo's scripts/setup.sh (the
# "deploy your own bot" button); it needs no owner-side secrets.
# Owner-only "add my own Google account" button: full add-account URL on the
# Google MCP dashboard, e.g. https://<google-mcp>/dashboard/<DASHBOARD_SECRET>/add
GOOGLE_DASHBOARD_ADD_URL=

# === Mini App onboarding screen + "Ask AI" helper ===
# The Mini App's /onboarding screen (walkthrough for a stranger deploying their
# OWN instance) includes a Q&A box backed by a system-prompt-only Claude call
# (app/onboarding/ai_help.py — condensed onboarding docs + common failure
# modes, not codebase RAG). Its backend route, POST /api/onboarding/ask, is the
# one endpoint NOT gated by owner auth (a stranger has nothing to authenticate
# with yet), so it's billed to and rate-limited against THIS instance's
# ANTHROPIC_API_KEY. Turn it off if you don't want to spend your Claude budget
# answering strangers' setup questions — the walkthrough itself still works.
ONBOARDING_AI_HELP_ENABLED=true
# Cheap model alias for the helper (opus|sonnet|haiku).
ONBOARDING_AI_MODEL=haiku
# Abuse mitigations for the un-authed route: max chars per question/history
# turn, a per-IP sliding-window cap (requests/hour, keyed on the real peer
# IP — NOT the client-supplied session header — in-memory, resets on
# restart, not distributed across replicas), and a hard aggregate cap across
# ALL callers combined per hour (backstop if per-IP keying is defeated by
# many distinct real callers).
ONBOARDING_AI_MAX_MESSAGE_CHARS=500
ONBOARDING_AI_RATE_LIMIT_PER_HOUR=20
ONBOARDING_AI_GLOBAL_HOURLY_CAP=100

# === External notify webhook (optional) ===
# Read directly from the environment (app/web/server.py). POST /cre/notify lets
# an external service (e.g. a scraper/cron on another box) deliver a text report
# to the owner via this bot, without ever holding BOT_TOKEN: it authenticates
# with `Authorization: Bearer <CRE_NOTIFY_SECRET>` and the bot sends the text to
# CRE_REPORT_CHAT_ID (falling back to the owner's DM). Both empty → endpoint off.
CRE_NOTIFY_SECRET=
CRE_REPORT_CHAT_ID=
