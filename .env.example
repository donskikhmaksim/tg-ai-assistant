# ── Telegram ────────────────────────────────────────────────────────────────
# @BotFather → /newbot. Then: Business Mode → Enable, Group Privacy → Turn off.
BOT_TOKEN=123456:ABC-DEF...

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGO_URL=mongodb://localhost:27017
MONGO_DB=tg_ai_assistant

# ── Claude (Anthropic) — Tier 2 разбор ─────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-opus-4-8

# ── Qwen (Ollama, OpenAI-совместимый endpoint) — Tier 1 триаж ──────────────────
QWEN_BASE_URL=http://localhost:11434/v1
QWEN_MODEL=qwen2.5:32b-instruct
QWEN_API_KEY=ollama

# ── ticktick-mcp (Railway) ─────────────────────────────────────────────────────
# Транспорт: sse | streamable-http (см. §12). URL до MCP-сервера.
TICKTICK_MCP_URL=https://ticktick-mcp.up.railway.app/sse
TICKTICK_MCP_TRANSPORT=sse
# Опциональный Bearer-токен, если сервер за авторизацией.
TICKTICK_MCP_AUTH_TOKEN=

# ── Пайплайн обработки ──────────────────────────────────────────────────────────
BATCH_INTERVAL_MIN=30
CONV_GAP_HOURS=6
MAX_LOOKBACK_HOURS=48
RAW_TTL_DAYS=30
DEFAULT_PROJECT=Inbox

# ── Прочее ──────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
